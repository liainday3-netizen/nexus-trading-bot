# Nexus Trading Bot — Environment Variables
# Copy this file to .env and fill in your values

# ── REQUIRED ──────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── API KEYS (optional but recommended) ──────────────────
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── RPC (default: public mainnet) ─────────────────────────
RPC_URL=https://api.mainnet-beta.solana.com

# ── TRADING PARAMS ────────────────────────────────────────
TRADE_SIZE_USD=2
MAX_TRADE_SIZE_USD=10
STOP_LOSS_PCT=5
DAILY_LOSS_PCT=10
MIN_CONFIDENCE=0.62
INTERVAL_SECONDS=30
SLIPPAGE_BPS=100

# ── SAFETY ────────────────────────────────────────────────
# Set to 'false' to enable live trading (default: dry run)
DRY_RUN=true

# ── STORAGE ───────────────────────────────────────────────
BRAIN_FILE=./brain.json
